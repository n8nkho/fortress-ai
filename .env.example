# Copy to .env and fill values. Never commit real secrets.

# System time — US Eastern only (see config/system_timezone.json)
FORTRESS_SYSTEM_TZ=America/New_York

FORTRESS_INSTANCE_NAME=Fortress-AI
FORTRESS_MODE=unified_ai

# Separate Alpaca paper account from Classic Fortress
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# DeepSeek (existing subscription — OpenAI-compatible API)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# --- Trading mode ---
# Dry-run: log decisions but never submit to Alpaca (Week 1 / safety).
FORTRESS_AI_DRY_RUN=1
# Paper trading with real Alpaca paper orders: set to 0 (keep ALPACA_BASE_URL paper).
# FORTRESS_AI_DRY_RUN=0

# Minimum model confidence (0–1) required before a paper order is sent. Higher = fewer trades.
# Reviewed and set 2026-06-20 — aligned with data/tunable_params_overrides.json and runtime gate.
FORTRESS_AI_MIN_CONFIDENCE=0.85
# When 1, SI will not auto-lower confidence below FORTRESS_AI_MIN_CONFIDENCE (floor = MIN_CONFIDENCE).
FORTRESS_AI_CONFIDENCE_FLOOR_LOCK=1
# Off-denylist symbols for unified AI enter_position (default: QQQ,IWM,DIA,...)
# FORTRESS_AI_ELIGIBLE_UNIVERSE=QQQ,IWM,DIA,JPM,XOM,UNH,COST,WMT,DIS,BA

# RSI entry hint in the LLM prompt (35–50). Self-improvement may override via data/tunable_params_overrides.json.
# FORTRESS_AI_RSI_ENTRY_THRESHOLD=43

# Optional extra instructions appended to the LLM prompt (capital preservation tone).
# FORTRESS_AI_PROMPT_BIAS=Default to wait unless the setup is exceptional; prioritize avoiding drawdowns over activity.

# --- Order / risk gates (pre_trade_gate; applies when FORTRESS_AI_DRY_RUN=0) ---
# Max USD notional per order (small size reduces blast radius on paper).
FORTRESS_MAX_ORDER_NOTIONAL_USD=3000
FORTRESS_MAX_ORDER_QTY=200
# Enforce spread / quote freshness when bid/ask provided by caller paths (recommended on).
FORTRESS_DATA_QUALITY_ENFORCE=1
FORTRESS_MAX_SPREAD_PCT=0.015
FORTRESS_MAX_QUOTE_AGE_SECONDS=75
# Optional: skip new BUY entries during ET windows (e.g. first/last minutes): "9:30-9:45,15:45-16:00"
# FORTRESS_ENTRY_BLACKOUT_WINDOWS_ET=

# --- Skim swarm (preferred intraday; systemd: fortress-ai-skim-swarm) ---
# SPY + equities/ETFs, 1 share each, long/short adaptive rules, no LLM. Disable fortress-ai-spy-agent when enabled.
# FORTRESS_SKIM_UNIVERSE=SPY,MSFT,GOOG,AMZN,AAPL,NASA,BRK.B,AGIX,LLY,V,MA,PLTR,CRWD
# FORTRESS_SKIM_DRY_RUN=1
# FORTRESS_SKIM_BASE_INTERVAL_SEC=45
# FORTRESS_SKIM_FAST_INTERVAL_SEC=12
# FORTRESS_SKIM_MAX_OPEN_POSITIONS=6
# Adaptive portfolio cap — floor from MAX_OPEN_POSITIONS, scales up on strong tape (default on)
# FORTRESS_ADAPTIVE_MAX_OPEN=1
# FORTRESS_SWARM_MAX_OPEN_CEILING=10
# FORTRESS_SWARM_MAX_OPEN_AGGRESSIVE=20
# FORTRESS_SKIM_DAILY_STOP_USD=-200
# FORTRESS_SKIM_SLOW_LANE_INTERVAL_SEC=60
# FORTRESS_SKIM_HIGH_VOL_SYMBOLS=LLY,CRWD
# FORTRESS_SKIM_HIGH_VOL_TARGET_CAP_USD=0.50
# FORTRESS_SKIM_MAX_STOP_USD=0.30
# FORTRESS_SKIM_MIN_STOP_USD=0.08
# FORTRESS_SKIM_STOP_TARGET_MULT=0.70
# FORTRESS_SKIM_DENYLIST=LLY,CRWD,MA,AVGO
# FORTRESS_SKIM_LIFETIME_PAUSE_MIN_PNL_USD=-3.0
# Bar source for live signals: auto (Alpaca when keys exist), alpaca, or yfinance.
# FORTRESS_SKIM_BAR_PROVIDER=auto
# Alpaca feed for bars: iex (free, real-time) or sip (all exchanges; recent SIP needs paid tier).
# FORTRESS_SKIM_BAR_FEED=iex
# In-memory bar cache TTL seconds (one batched data-API call per wave when expired).
# FORTRESS_SKIM_BAR_CACHE_SEC=25
# Min session exits before per-symbol param tuning (then every N exits).
# FORTRESS_SKIM_IMPROVE_MIN_EXITS=10
# FORTRESS_SKIM_IMPROVE_INTERVAL_EXITS=5
# Per-symbol continuous RTH self-improvement (each symbol learns independently):
# FORTRESS_SKIM_CONTINUOUS_SI=1
# FORTRESS_SKIM_IMPROVE_EVERY_EXIT=1
# FORTRESS_SKIM_BLOCK_STREAK_THRESHOLD=3
# FORTRESS_SKIM_SESSION_EXPECTANCY_MIN_USD=-0.05
# Swarm-level session SI (negative edge / over-churn — complements per-symbol SI):
# FORTRESS_SKIM_SWARM_SESSION_SI=1
# FORTRESS_SKIM_CHURN_MAX_EXITS_SESSION=22
# FORTRESS_SKIM_CHURN_MIN_WIN_RATE=0.38
# FORTRESS_SKIM_CHURN_MIN_EXITS=8
# Clip ladder (skim only): max exposure per symbol with 1-share SI-gated clips
# Clear-winner clip ladder — add 2nd–5th share on open winners (skim + infra, default ON)
# FORTRESS_SWARM_CLIP_LADDER=1
# FORTRESS_SWARM_MAX_SHARES_PER_SYMBOL=5
# FORTRESS_SWARM_CLIP_SIZE=1
# FORTRESS_SWARM_CLIP_MIN_GAP_SEC=180
# FORTRESS_SWARM_CLIP_MIN_HOLD_SEC=90
# FORTRESS_SKIM_CLIP_LADDER=1
# FORTRESS_INFRA_CLIP_LADDER=1
# Legacy aliases still honored:
# FORTRESS_SKIM_MAX_SHARES_PER_SYMBOL=5
# Scenario stress (replay recent decisions.jsonl): scripts/skim_scenario_stress.py --sessions 5 --apply
# EOD research cycle (cron 6 PM ET Mon–Fri): scripts/eod_research_cycle.sh → promote/kill hypotheses + --apply
# FORTRESS_MOVEMENT_ANTICIPATION=1
# FORTRESS_MOVEMENT_ANTICIPATION_GATE=1
# FORTRESS_SKIM_SHADOW_LANE=1
# FORTRESS_SKIM_SHADOW_PROMOTE_MIN_EXITS=8
# --- Infra swarm (AI infrastructure SRP; systemd: fortress-ai-infra-swarm) ---
# Adaptive universe from candidate pool; anchor SMH for stack reference.
# FORTRESS_INFRA_DRY_RUN=1
# FORTRESS_INFRA_ADAPTIVE_UNIVERSE=1
# FORTRESS_INFRA_ANCHOR=SMH
# FORTRESS_INFRA_SEED_UNIVERSE=NVDA,AMD,AVGO,MRVL,SMCI,ANET,COHR,AMAT,LRCX,KLAC,VRT,MU
# FORTRESS_INFRA_CANDIDATE_POOL=NVDA,AMD,AVGO,MRVL,ARM,TSM,SMCI,ANET,COHR,AMAT,LRCX,KLAC,VRT,MU,ON,EQIX
# FORTRESS_INFRA_CONTINUOUS_SI=1
# FORTRESS_INFRA_IMPROVE_EVERY_EXIT=1
# FORTRESS_INFRA_MAX_OPEN_POSITIONS=6
# FORTRESS_INFRA_DAILY_STOP_USD=-150
# FORTRESS_INFRA_MAX_STACK_LONG_PER_LAYER=2
# FORTRESS_INFRA_MAX_L1_GROSS_LONG=3
# FORTRESS_INFRA_SWARM_SESSION_SI=1
# FORTRESS_INFRA_CHURN_MAX_EXITS_SESSION=12
# FORTRESS_INFRA_CHURN_MIN_WIN_RATE=0.38
# FORTRESS_INFRA_CHURN_MIN_EXITS=6
# FORTRESS_INFRA_SESSION_EXPECTANCY_MIN_USD=-0.05

# Per-symbol adaptive side/symbol pauses and causation (each ticker independent):
# FORTRESS_SKIM_SIDE_PAUSE_MIN_EXITS=4
# FORTRESS_SKIM_SYMBOL_PAUSE_MIN_EXITS=8
# FORTRESS_SKIM_CAUSATION_MIN_SAMPLES=2
# Monitor: scripts/skim_swarm_analyze.py --minutes 30 --auto-tune
# FORTRESS_AI_SYMBOL_DENYLIST=SPY,NVDA,MSFT,GOOG,AMZN,SOXX,NASA,BRK.B,AGIX,AVGO,LLY,V,MA,PLTR,CRWD

# --- SPY/DIA intraday agent (legacy; separate systemd: fortress-ai-spy-agent) ---
# Same Alpaca/DeepSeek keys; isolated logs under data/spy_intraday/
# FORTRESS_SPY_INSTANCE_NAME=Fortress-SPY-Intraday
# FORTRESS_INDEX_SYMBOL=SPY
# FORTRESS_SPY_DRY_RUN=1
# FORTRESS_SPY_MAX_EXPOSURE_USD=10000
# FORTRESS_SPY_LADDER_RUNGS=3
# FORTRESS_SPY_LOOP_SECONDS=300
# FORTRESS_SPY_LOOP_SECONDS_ACTIVE=180
# FORTRESS_SPY_MIN_CONFIDENCE=0.85  # effective floor 0.65 in code (values below 0.65 clamp up)
# FORTRESS_SPY_MANUAL_ONLY=0
# FORTRESS_SPY_DATA_DIR=/home/ubuntu/fortress-ai/data/spy_intraday
# Include US futures (ES/NQ/YM/RTY) + Asia/Europe index context in SPY agent prompts (1=on)
# FORTRESS_SPY_GLOBAL_MARKETS=1
# Self-improvement (recursive skim tuning; immutable: max exposure, EOD flat)
# FORTRESS_SPY_SI_ENABLED=1  # set 0 to pause auto-tuning until you have executed fills
# FORTRESS_SPY_SI_EVERY_N_CYCLES=5
# FORTRESS_SPY_SI_MIN_CYCLES=8
# FORTRESS_SPY_SI_AUTO_APPLY=1

# Cost & cadence
# Set to 1 to disable ALL automatic LLM cycles (including US market hours). Agent idles until you use
# dashboard "Run AI cycle now" or touch data/agent_on_demand_cycle.flag.
# FORTRESS_AI_MANUAL_ONLY=1
# Slower loops = fewer decisions per day (often preferable when minimizing churn).
# Used during US equity RTH (Mon–Fri 9:30–4:00 PM America/New_York) for automatic cycles when MANUAL_ONLY is unset.
# Weekends (Sat–Sun ET) are always manual/on-demand — no env toggle needed.
FORTRESS_AI_LOOP_SECONDS=300
# After a cycle that finishes in off-hours, sleep up to this many seconds before the next loop
# iteration (on-demand "Run AI cycle now" can still wake earlier). No recurring off-hours LLM runs.
FORTRESS_AI_LOOP_SECONDS_OFF_HOURS=1800
# How often the agent wakes to check for off-hours on-demand when idling (no LLM call each wake).
# FORTRESS_AI_OFF_HOURS_POLL_SECONDS=60
# Weekly DeepSeek spend cap. When exceeded: degrade = heuristic cycles (no LLM); stop = halt agent loop.
FORTRESS_AI_WEEKLY_COST_CAP_USD=5.0
FORTRESS_AI_WEEKLY_BUDGET_MODE=degrade
# Unified self-improvement in agent loop (every N cycles). SPY uses FORTRESS_SPY_SI_* separately.
# FORTRESS_AI_SI_ENABLED=1
# FORTRESS_AI_SI_EVERY_N_CYCLES=10
# FORTRESS_AI_SI_AUTO_APPLY=1   # Tier-0/1 apply without dashboard approval (default on)
FORTRESS_AI_MAX_PROMPT_CHARS=7500
FORTRESS_AI_MAX_OBS_CHARS=3500

# Dashboard — use any port already allowed in your cloud firewall (e.g. 8050, 8060, 8080).
# Classic Fortress Command Center often uses 8083; pick a free port on the VM (`ss -tlnp`).
FORTRESS_AI_DASHBOARD_PORT=8050
# Bind address: 127.0.0.1 = only this machine (use with SSH tunnel / reverse proxy). Default 0.0.0.0 = LAN + public.
# FORTRESS_AI_DASHBOARD_HOST=0.0.0.0
#
# Optional HTTP Basic lock (browser login for /, APIs, static). Password is sent in clear unless you use HTTPS in front
# (see deploy/README.md — nginx + TLS). Generate a long random password; do not reuse banking or email passwords.
# FORTRESS_AI_DASHBOARD_BASIC_USER=you
# FORTRESS_AI_DASHBOARD_BASIC_PASSWORD=change-me-to-long-random
# Allow unauthenticated GET /api/health only (uptime monitors). Default: health also requires Basic when auth is on.
# FORTRESS_AI_DASHBOARD_AUTH_EXEMPT_HEALTH=0

# Optional: text shown in browser tab + top banner so you can confirm deploy (default v2-2026-05-04).
# FORTRESS_AI_DASHBOARD_BUILD=my-vm-may4

# Optional: isolate data dir (default ./data under fortress-ai)
# FORTRESS_AI_DATA_DIR=/home/ubuntu/fortress-ai/data

# Optional: Classic Fortress data/ path — powers the "Classic" comparison drawer only (historical decisions_log.jsonl).
# Does not affect live Alpaca; unset or leave blank to hide Classic ledger stats.
# CLASSIC_DATA_DIR=/home/ubuntu/trading-bot/data
# Classic Alpaca for comparison drawer (optional; else reads trading-bot/.env Alpaca keys only for that call)
# CLASSIC_ALPACA_API_KEY=
# CLASSIC_ALPACA_SECRET_KEY=
# CLASSIC_ALPACA_BASE_URL=https://paper-api.alpaca.markets
# CLASSIC_ENV_FILE=/home/ubuntu/trading-bot/.env

# Dashboard CPU tuning (defaults: state cache 25s, SSE 5s, classic portfolio cache 60s)
# FORTRESS_AI_DASHBOARD_STATE_CACHE_SEC=25
# FORTRESS_AI_DASHBOARD_SSE_SEC=5
# FORTRESS_AI_CLASSIC_PORTFOLIO_CACHE_SEC=60

# If your shell exports Classic ALPACA_* (check: env | grep ALPACA), set this so values in THIS file win:
FORTRESS_DOTENV_OVERRIDE=1
# (Fortress loads .env twice: first pass picks up this flag from the file; second pass overrides shell exports.)

# Optional: share halt file with Classic (absolute path to operator_trading_halt.json)
# FORTRESS_SHARED_HALT_PATH=

# Global halt via env is honored by pre_trade_gate on BOTH stacks:
# FORTRESS_TRADING_HALT=0

# --- Trade belief memory (P7) ---
# Inject LEARNED BELIEFS section into AI Mind prompt (1=on)
FORTRESS_BELIEF_INJECT=1
# Process external P&L ledger into data/beliefs/beliefs.json (1=on)
FORTRESS_AI_BELIEF_LEDGER_HOOK=1
# Default path to Classic Fortress closed-trade ledger (JSONL)
# FORTRESS_AI_EXTERNAL_LEDGER_PATH=/home/ubuntu/trading-bot/data/pnl_ledger.jsonl
# Regime label source for beliefs (optional)
# FORTRESS_AI_REGIME_JSON=/home/ubuntu/trading-bot/data/daily_risk_params.json
# FORTRESS_AI_DEFAULT_STRATEGY=mean_reversion

# --- Domain intelligence ingest (P8) ---
# 0 = wire ingest signals into AI Mind prompt + belief sync (required for domain LLM learning).
# 1 = read-only: save JSON only; no prompt injection.
FORTRESS_INGEST_READ_ONLY=0
# LLM extraction of lessons from domain/trade outcomes into domain knowledge + beliefs (1=on)
FORTRESS_AI_DOMAIN_LLM_LEARN=1
# FRED series (comma-separated) — needs FRED_API_KEY
# FORTRESS_FRED_SERIES=VIXCLS,DGS10,T10Y2Y,UMCSENT,DCOILWTICO
# FRED_API_KEY=
# NEWS_API_KEY=
# User-Agent for SEC / CFTC fetches (some endpoints require a descriptive UA)
# FORTRESS_SEC_USER_AGENT=YourOrg/1.0 (you@example.com)

# --- Edge quality (P1–P6) — skim + infra swarms ---
# Master switch (1=on). Gates + brackets apply when enabled.
FORTRESS_EDGE_QUALITY=1
FORTRESS_BRACKET_EXITS=1
FORTRESS_RR_GATE=1
FORTRESS_COST_GATE=1
FORTRESS_EXPECTANCY_GATE=1
FORTRESS_PASSIVE_ENTRY=1
FORTRESS_TIME_STOP=1
# FORTRESS_RR_SAFETY_MARGIN=1.15
# FORTRESS_COST_GATE_MULT=2.5
# FORTRESS_TIME_STOP_SEC=120
# FORTRESS_TIME_STOP_MIN_PROGRESS=0.20
# FORTRESS_EST_SLIPPAGE_USD=0.02
# FORTRESS_EXPECTANCY_MIN_EXITS=4
# FORTRESS_EXPECTANCY_MIN_USD=-0.01

# RTH intraday autonomous SI — anomaly scan + edge autofix every 15 min during market hours
FORTRESS_RTH_INTRADAY_SI=1
FORTRESS_RTH_SI_INTERVAL_SEC=900
# FORTRESS_OPERATOR_STATUS_INTERVAL_SEC=900
# FORTRESS_UNIFIED_ENTER_COOLDOWN_SEC=900

# Market consciousness — 5-year hourly RTH slot memory for agent decisions
FORTRESS_MARKET_CONSCIOUSNESS=1
FORTRESS_HOURLY_KNOWLEDGE_YEARS=5
FORTRESS_CONSCIOUSNESS_POSTURE=1
FORTRESS_SESSION_DIARY=1
FORTRESS_PROACTIVE_SI=1
FORTRESS_SESSION_INTENT=1
# FORTRESS_CONSCIOUSNESS_MIN_EXITS=4
# Rebuild: python3 scripts/build_hourly_market_knowledge.py  (cron weekly recommended)

# Autonomous code SI — assess + implement queue items (Cursor agent); human review before commit/push
FORTRESS_SI_AUTO_CODE=1
FORTRESS_SI_AUTO_CODE_MAX_PER_DAY=2
FORTRESS_SI_AUTO_CODE_REQUIRE_E2E=1
FORTRESS_SI_AUTO_COMMIT=false
FORTRESS_SI_AUTO_PUSH=false
FORTRESS_SI_AUTO_APPROVE=0
FORTRESS_SI_AUTO_ASSESS_LIMIT=5
FORTRESS_SI_AUTO_IMPLEMENT_LIMIT=1

# Tier-2 prompt promotion: ledger health gate (default off).
# Blocks overlay approve / A/B-winner-B when realized PnL ledger is unstable — timing safeguard, NOT per-candidate prompt WF.
# FORTRESS_PROMPT_LEDGER_HEALTH_GATE_ENABLED=1
# FORTRESS_PROMPT_WF_GATE_ENABLED=1   # legacy alias for the same gate

# FORTRESS_SI_CURSOR_BIN=/home/ubuntu/.local/bin/cursor-agent
# FORTRESS_SI_CURSOR_TRUST=1
# CURSOR_API_KEY=

# SI Singularity — surpass floor objectives with dynamic aspire targets (default ON)
# FORTRESS_SI_SINGULARITY=1


# Copy to .env and fill values. Never commit real secrets.

FORTRESS_INSTANCE_NAME=Fortress-AI
FORTRESS_MODE=unified_ai

# Separate Alpaca paper account from Classic Fortress
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# DeepSeek (existing subscription — OpenAI-compatible API)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# --- Trading mode ---
# Dry-run: log decisions but never submit to Alpaca (Week 1 / safety).
FORTRESS_AI_DRY_RUN=1
# Paper trading with real Alpaca paper orders: set to 0 (keep ALPACA_BASE_URL paper).
# FORTRESS_AI_DRY_RUN=0

# Minimum model confidence (0–1) required before a paper order is sent. Higher = fewer trades.
# Conservative paper: 0.85–0.92 | looser exploration: 0.75–0.8
FORTRESS_AI_MIN_CONFIDENCE=0.85

# RSI entry hint in the LLM prompt (35–50). Self-improvement may override via data/tunable_params_overrides.json.
# FORTRESS_AI_RSI_ENTRY_THRESHOLD=43

# Optional extra instructions appended to the LLM prompt (capital preservation tone).
# FORTRESS_AI_PROMPT_BIAS=Default to wait unless the setup is exceptional; prioritize avoiding drawdowns over activity.

# --- Order / risk gates (pre_trade_gate; applies when FORTRESS_AI_DRY_RUN=0) ---
# Max USD notional per order (small size reduces blast radius on paper).
FORTRESS_MAX_ORDER_NOTIONAL_USD=3000
FORTRESS_MAX_ORDER_QTY=200
# Enforce spread / quote freshness when bid/ask provided by caller paths (recommended on).
FORTRESS_DATA_QUALITY_ENFORCE=1
FORTRESS_MAX_SPREAD_PCT=0.015
FORTRESS_MAX_QUOTE_AGE_SECONDS=75
# Optional: skip new BUY entries during ET windows (e.g. first/last minutes): "9:30-9:45,15:45-16:00"
# FORTRESS_ENTRY_BLACKOUT_WINDOWS_ET=

# Cost & cadence
# Set to 1 to disable ALL automatic LLM cycles (including US market hours). Agent idles until you use
# dashboard "Run AI cycle now" or touch data/agent_on_demand_cycle.flag.
# FORTRESS_AI_MANUAL_ONLY=1
# Slower loops = fewer decisions per day (often preferable when minimizing churn).
# Used during US equity RTH (Mon–Fri 9:30–4:00 PM America/New_York) for automatic cycles when MANUAL_ONLY is unset.
FORTRESS_AI_LOOP_SECONDS=300
# After a cycle that finishes in off-hours, sleep up to this many seconds before the next loop
# iteration (on-demand "Run AI cycle now" can still wake earlier). No recurring off-hours LLM runs.
FORTRESS_AI_LOOP_SECONDS_OFF_HOURS=1800
# How often the agent wakes to check for off-hours on-demand when idling (no LLM call each wake).
# FORTRESS_AI_OFF_HOURS_POLL_SECONDS=60
# Weekly DeepSeek spend cap; agent stops when exceeded (raise if you want longer paper runs).
FORTRESS_AI_WEEKLY_COST_CAP_USD=5.0
FORTRESS_AI_MAX_PROMPT_CHARS=7500
FORTRESS_AI_MAX_OBS_CHARS=3500

# Dashboard — use any port already allowed in your cloud firewall (e.g. 8050, 8060, 8080).
# Classic Fortress Command Center often uses 8083; pick a free port on the VM (`ss -tlnp`).
FORTRESS_AI_DASHBOARD_PORT=8050

# Optional: text shown in browser tab + top banner so you can confirm deploy (default v2-2026-05-04).
# FORTRESS_AI_DASHBOARD_BUILD=my-vm-may4

# Optional: isolate data dir (default ./data under fortress-ai)
# FORTRESS_AI_DATA_DIR=/home/ubuntu/fortress-ai/data

# Optional: Classic Fortress data/ path — powers the "Classic" comparison drawer only (historical decisions_log.jsonl).
# Does not affect live Alpaca; unset or leave blank to hide Classic ledger stats.
# CLASSIC_DATA_DIR=/home/ubuntu/trading-bot/data

# If your shell exports Classic ALPACA_* (check: env | grep ALPACA), set this so values in THIS file win:
FORTRESS_DOTENV_OVERRIDE=1
# (Fortress loads .env twice: first pass picks up this flag from the file; second pass overrides shell exports.)

# Optional: share halt file with Classic (absolute path to operator_trading_halt.json)
# FORTRESS_SHARED_HALT_PATH=

# Global halt via env is honored by pre_trade_gate on BOTH stacks:
# FORTRESS_TRADING_HALT=0
